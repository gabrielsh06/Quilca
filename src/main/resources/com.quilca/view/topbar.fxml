<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="topbar" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quilca.controller.TopBarController">

    <HBox>
        <MenuBar HBox.hgrow="ALWAYS">
            <Menu mnemonicParsing="false" text="File">
                <MenuItem mnemonicParsing="false" onAction="#handleRead" text="Open" />
                <MenuItem mnemonicParsing="false" onAction="#handleSave" text="Save" />
            </Menu>
            <Menu mnemonicParsing="false" text="View">
                <Menu mnemonicParsing="false" text="Theme">
                    <MenuItem mnemonicParsing="false" onAction="#darkMode" text="Dark Mode"/>
                    <MenuItem mnemonicParsing="false" onAction="#lightMode" text="Light Mode"/>
                </Menu>
            </Menu>
            <Menu mnemonicParsing="false" text="About">
                <MenuItem mnemonicParsing="false" onAction="#about" text="Quilca" />
            </Menu>
        </MenuBar>
    </HBox>
    <HBox styleClass="container-tools">
        <Button mnemonicParsing="false" text="Button" />
    </HBox>
</VBox>
