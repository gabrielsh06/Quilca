<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.Integer?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.HBox?>

<HBox xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quilca.controller.FormatBarController">

    <Button onAction="#onBold" style="-fx-font-weight: bold;" text="B" />
    <Button onAction="#onItalic" style="-fx-font-style: italic;" text="I" />
    <ComboBox fx:id="fontSize" onAction="#onSizeChange" promptText="12">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <Integer fx:value="9" />
                <Integer fx:value="10" />
                <Integer fx:value="12" />
                <Integer fx:value="14" />
                <Integer fx:value="16" />
                <Integer fx:value="18" />
                <Integer fx:value="24" />
                <Integer fx:value="36" />
            </FXCollections>
        </items>
    </ComboBox>
    <Button fx:id="colorButton" onAction="#onColorPicker" text="Colors" />
</HBox>
