<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import java.lang.Integer?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.ColorPicker?>

<HBox xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.quilca.controller.FormatBarController">

    <Button text="B" onAction="#onBold" style="-fx-font-weight: bold;"/>
    <Button text="I" onAction="#onItalic" style="-fx-font-style: italic;"/>
    <ComboBox fx:id="fontSize" onAction="#onSizeChange">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <Integer fx:value="10"/>
                <Integer fx:value="12"/>
                <Integer fx:value="14"/>
                <Integer fx:value="16"/>
                <Integer fx:value="18"/>
                <Integer fx:value="24"/>
                <Integer fx:value="36"/>
            </FXCollections>
        </items>
    </ComboBox>
    <ColorPicker fx:id="colorPicker" onAction="#onColorChange"/>
</HBox>